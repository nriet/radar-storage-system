{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Effect": "Allow",
            "Action": ["s3:ListBucket", "s3:GetBucketLocation"],
            "Resource": ["arn:aws:s3:::radar-data", "arn:aws:s3:::radar-archive"]
        },
        {
            "Effect": "Allow",
            "Action": [
                "s3:PutObject", "s3:GetObject", "s3:DeleteObject",
                "s3:PutObjectTagging", "s3:GetObjectTagging",
                "s3:AbortMultipartUpload"
            ],
            "Resource": ["arn:aws:s3:::radar-data/*", "arn:aws:s3:::radar-archive/*"]
        }
    ]
}
